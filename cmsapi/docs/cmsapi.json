{
    "definitions": {},
    "info": {
        "contact": {
            "email": "",
            "responsibleDeveloper": "",
            "responsibleOrganization": "",
            "url": ""
        },
        "description": "REST-API to connect with UniBE CMS",
        "termsOfService": "",
        "title": "CMSAPI",
        "version": "2.0"
    },
    "paths": {
        "/v1/announcements/agenda/": {
            "get": {
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "No events found"
                    },
                    "404": {
                        "description": "Problem with connection to agenda.unibe.ch"
                    }
                },
                "summary": "Retrieve events from agenda.unibe.ch",
                "tags": [
                    "News and Events"
                ]
            }
        },
        "/v1/announcements/containers/": {
            "get": {
                "parameters": [
                    {
                        "description": "Retrieve containers deep in the hierarchy (default mode: only at root level of a subsite)",
                        "in": "query",
                        "name": "getall",
                        "required": false,
                        "type": "boolean"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "Empty response"
                    }
                },
                "summary": "Retrieve identifiers of containers with news and/or events as hierarchical overview",
                "tags": [
                    "News and Events"
                ]
            }
        },
        "/v1/announcements/events/{uuid}/": {
            "get": {
                "parameters": [
                    {
                        "description": "The identifier of the newscontainer taken from /announcements/containers",
                        "in": "path",
                        "name": "uuid",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "description": "Filter by given creation date as starting point (format: YYYY[MM[DD]] / default: 1 year ago)",
                        "in": "query",
                        "name": "created",
                        "required": false,
                        "type": "date"
                    },
                    {
                        "description": "Filter by given modification date as starting point (format: YYYY[MM[DD]] / default: 1 year ago)",
                        "in": "query",
                        "name": "changed",
                        "required": false,
                        "type": "date"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "No events found"
                    }
                },
                "summary": "Retrieve only events of the specified identifier",
                "tags": [
                    "News and Events"
                ]
            }
        },
        "/v1/announcements/news/{uuid}/": {
            "get": {
                "parameters": [
                    {
                        "description": "The identifier of the newscontainer taken from /announcements/containers",
                        "in": "path",
                        "name": "uuid",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "description": "Filter by given creation date as starting point (format: YYYY[MM[DD]] / default: 1 year ago)",
                        "in": "query",
                        "name": "created",
                        "required": false,
                        "type": "date"
                    },
                    {
                        "description": "Filter by given modification date as starting point (format: YYYY[MM[DD]] / default: 1 year ago)",
                        "in": "query",
                        "name": "changed",
                        "required": false,
                        "type": "date"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "No news found"
                    }
                },
                "summary": "Retrieve only news of the specified identifier",
                "tags": [
                    "News and Events"
                ]
            }
        },
        "/v1/announcements/{uuid}/": {
            "get": {
                "parameters": [
                    {
                        "description": "The identifier of the newscontainer taken from /announcements/containers",
                        "in": "path",
                        "name": "uuid",
                        "required": true,
                        "type": "string"
                    },
                    {
                        "description": "Filter by given creation date as starting point (format: YYYY[MM[DD]] / default: 1 year ago)",
                        "in": "query",
                        "name": "created",
                        "required": false,
                        "type": "date"
                    },
                    {
                        "description": "Filter by given modification date as starting point (format: YYYY[MM[DD]] / default: 1 year ago)",
                        "in": "query",
                        "name": "changed",
                        "required": false,
                        "type": "date"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "No news/events found"
                    }
                },
                "summary": "Retrieve all news/events of the specified identifier",
                "tags": [
                    "News and Events"
                ]
            }
        },
        "/v1/canteens/overview/": {
            "get": {
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "No canteens found"
                    }
                },
                "summary": "Retrieve an overview of all canteens from mensa.unibe.ch",
                "tags": [
                    "Canteens"
                ]
            }
        },
        "/v1/canteens/{uuid}/": {
            "get": {
                "parameters": [
                    {
                        "description": "The identifier of the canteen",
                        "in": "path",
                        "name": "uuid",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "No canteens found"
                    }
                },
                "summary": "Retrieve details of a canteen from mensa.unibe.ch",
                "tags": [
                    "Canteens"
                ]
            }
        },
        "/v0/servicelinks/": {
            "get": {
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "No information found"
                    }
                },
                "summary": "Returns possible values for an {item} to be retrieved",
                "tags": [
                    "Service Links"
                ]
            }
        },
        "/v0/servicelinks/{item}/": {
            "get": {
                "parameters": [
                    {
                        "description": "A possible value taken from /servicelinks",
                        "in": "path",
                        "name": "item",
                        "required": true,
                        "type": "string"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "204": {
                        "description": "No information found"
                    }
                },
                "summary": "Retrieve information from the requested item",
                "tags": [
                    "Service Links"
                ]
            }
        }
    },
    "swagger": "2.0"
}